<script>
  const BIN_ID  = "69bf344caa77b81da907c8da";
  const API_KEY = "$2a$10$GGFic.Aoa/zbh7/pyaOuTO2QT0oJhPWSR16K502xz4RuWtRQc5Xmi";
  const BASE    = `https://api.jsonbin.io/v3/b/${BIN_ID}`;
  const HEADERS = { "Content-Type":"application/json", "X-Master-Key": API_KEY };

  const SLOTS_START = 8, SLOTS_END = 21, MAX = 2;
  let visits = [];
  let selectedDate = new Date(); selectedDate.setHours(0,0,0,0);
  let selectedSlot = null;
  let currentTab = 'upcoming';
  let saving = false;

  // ── API ────────────────────────────────────────────────
  async function loadVisits() {
    try {
      const r = await fetch(BASE + "/latest", { headers: { "X-Master-Key": API_KEY } });
      const d = await r.json();
      visits = (d.record || []).filter(v => v && v.id && v.id !== "init");
    } catch(e) { visits = []; }
    render();
  }

  async function saveVisits() {
    await fetch(BASE, { method:"PUT", headers: HEADERS, body: JSON.stringify(visits) });
  }

  // ── Helpers ────────────────────────────────────────────
  function fmtDate(d) {
    const days=['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
    const months=['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
    return `${days[d.getDay()]} ${d.getDate()} ${months[d.getMonth()]}`;
  }
  function fmtTime(h,m){ return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`; }
  function slotKey(date,h,m){ return `${date.toISOString().slice(0,10)}_${fmtTime(h,m)}`; }
  function slotVisits(key){ return visits.filter(v=>v.slot===key); }
  function isSlotPast(h,m){
    const now=new Date(), today=new Date(); today.setHours(0,0,0,0);
    if(selectedDate>today) return false;
    if(selectedDate<today) return true;
    return now.getHours()>h||(now.getHours()===h&&now.getMinutes()>=m+30);
  }
  function generateSlots(){
    const s=[];
    for(let h=SLOTS_START;h<SLOTS_END;h++){ s.push({h,m:0}); s.push({h,m:30}); }
    return s.filter(x=>!(x.h===SLOTS_END-1&&x.m===30));
  }

  // ── Render ─────────────────────────────────────────────
  function render(){ renderDateLabel(); renderSlots(); renderList(); renderNext(); }

  function renderDateLabel(){ document.getElementById('dateLabel').textContent = fmtDate(selectedDate); }

  function renderSlots(){
    const grid = document.getElementById('slotsGrid');
    grid.innerHTML = '';
    generateSlots().forEach(({h,m})=>{
      const key = slotKey(selectedDate,h,m);
      const count = slotVisits(key).reduce((a,v)=>a+v.count,0);
      const past = isSlotPast(h,m), full = count>=MAX, partial = count===1;
      const isSel = selectedSlot===key;
      const btn = document.createElement('button');
      btn.className='slot-btn'+(isSel?' selected':'')+(full?' full':'')+(partial&&!isSel?' partial':'')+(past?' past':'');
      btn.innerHTML=`${fmtTime(h,m)}<span class="slot-count">${full?'Lleno':count===0?'2 lugares':'1 lugar'}</span>`;
      if(!full&&!past) btn.onclick=()=>{ selectedSlot=(selectedSlot===key)?null:key; renderSlots(); };
      grid.appendChild(btn);
    });
  }

  function renderNext(){
    const now=new Date();
    const future=visits.filter(v=>{
      const [d,t]=v.slot.split('_'); const [hh,mm]=t.split(':').map(Number);
      const dt=new Date(d); dt.setHours(hh,mm,0,0); return dt>=now;
    }).sort((a,b)=>a.slot.localeCompare(b.slot));
    const el=document.getElementById('nextContent');
    if(!future.length){ el.innerHTML='<span class="next-none">Sin turnos próximos</span>'; return; }
    const n=future[0], [d,t]=n.slot.split('_'), dateObj=new Date(d+'T00:00:00');
    el.innerHTML=`<div class="next-visit">🕐 ${t}</div><div style="opacity:0.8;font-size:0.8rem;margin-bottom:6px">${fmtDate(dateObj)}</div><div>${n.names}</div>`;
  }

  function renderList(){
    const el=document.getElementById('visitList');
    const now=new Date();
    let list=[...visits].sort((a,b)=>a.slot.localeCompare(b.slot));
    if(currentTab==='upcoming') list=list.filter(v=>{
      const [d,t]=v.slot.split('_'); const [hh,mm]=t.split(':').map(Number);
      const dt=new Date(d); dt.setHours(hh,mm,0,0); return dt>=now;
    });
    if(!list.length){ el.innerHTML='<div class="empty-state">No hay turnos aún 🌱</div>'; return; }
    const grouped={};
    list.forEach(v=>{ if(!grouped[v.slot]) grouped[v.slot]=[]; grouped[v.slot].push(v); });
    el.innerHTML=Object.entries(grouped).map(([slot,vs])=>{
      const [d,t]=slot.split('_'), dateObj=new Date(d+'T00:00:00');
      const total=vs.reduce((a,v)=>a+v.count,0), isFull=total>=MAX;
      const names=vs.map(v=>v.names).join(', ');
      const [hh,mm]=t.split(':').map(Number), dt=new Date(d); dt.setHours(hh,mm,0,0);
      const isPast=dt<now;
      return `<div class="visit-item" style="${isPast?'opacity:0.5':''}">
        <div class="visit-time">${t}<span class="visit-date-tag">${fmtDate(dateObj)}</span></div>
        <div class="visit-names">${names}</div>
        <span class="visit-badge ${isFull?'full':'open'}">${total}/2</span>
        ${vs.map(v=>`<button class="delete-btn" title="Cancelar" onclick="deleteVisit('${v.id}')">✕</button>`).join('')}
      </div>`;
    }).join('');
  }

  // ── Actions ────────────────────────────────────────────
  function toggleForm(){
    document.getElementById('mainForm').style.display =
      document.getElementById('agreeCheck').checked ? 'block' : 'none';
    if(document.getElementById('agreeCheck').checked) loadVisits();
  }

  function changeDay(d){ selectedDate=new Date(selectedDate); selectedDate.setDate(selectedDate.getDate()+d); selectedSlot=null; render(); }
  function setTab(t){ currentTab=t; document.getElementById('tab-upcoming').classList.toggle('active',t==='upcoming'); document.getElementById('tab-all').classList.toggle('active',t==='all'); renderList(); }

  function showMsg(txt,type){ const el=document.getElementById('msg'); el.textContent=txt; el.className='msg '+type; el.style.display='block'; setTimeout(()=>el.style.display='none',3500); }

  async function register(){
    if(saving) return;
    const n1=document.getElementById('name1').value.trim();
    const n2=document.getElementById('name2').value.trim();
    if(!n1) return showMsg('Por favor ingresá tu nombre.','error');
    if(!selectedSlot) return showMsg('Seleccioná un horario primero.','error');
    const existing=slotVisits(selectedSlot).reduce((a,v)=>a+v.count,0);
    const adding=n2?2:1;
    if(existing+adding>MAX) return showMsg(`Solo queda ${MAX-existing} lugar en ese horario.`,'error');
    saving=true;
    document.getElementById('regBtn').disabled=true;
    // reload fresh before saving to avoid race conditions
    await loadVisits();
    const existingFresh=slotVisits(selectedSlot).reduce((a,v)=>a+v.count,0);
    if(existingFresh+adding>MAX){ saving=false; document.getElementById('regBtn').disabled=false; return showMsg('Ese horario se llenó justo ahora. Elegí otro.','error'); }
    const names=n2?`${n1} y ${n2}`:n1;
    visits.push({ id: Date.now().toString(), slot: selectedSlot, names, count: adding });
    await saveVisits();
    document.getElementById('name1').value='';
    document.getElementById('name2').value='';
    selectedSlot=null; saving=false;
    document.getElementById('regBtn').disabled=false;
    showMsg(`✅ Turno reservado para ${names}`,'success');
    render();
  }

  async function deleteVisit(id){
    if(!confirm('¿Cancelar este turno?')) return;
    visits=visits.filter(v=>v.id!==id);
    await saveVisits();
    render();
  }

  // Auto-refresh cada 30 seg para ver turnos de otros
  setInterval(()=>{ if(document.getElementById('agreeCheck').checked) loadVisits(); }, 30000);

  renderDateLabel();
</script>

</body>
