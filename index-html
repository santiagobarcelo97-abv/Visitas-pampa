<div class="container">

  <div class="left-panel">
    <div class="card">
      <h2>📅 Elegí el día</h2>
      <div class="date-nav">
        <button onclick="changeDay(-1)">‹</button>
        <span id="dateLabel"></span>
        <button onclick="changeDay(1)">›</button>
      </div>
    </div>

